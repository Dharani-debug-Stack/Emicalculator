<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="MasterSuite" thread-count="5">

    <groups>
        <run>
            <include name="Master"/>
            <include name="Sanity"/>
            <exclude name="Regression"/>
<!--            <include name="Regression"/>-->
        </run>
    </groups>

    <listeners>
<!--        <listener class-name="org.testng.reporters.EmailableReporter2"/>-->
        <!-- Extent Reports -->
        <listener class-name="utilities.ExtentListener"/>
    </listeners>


    <test name="EMI Test">
        <parameter name="os" value="Windows"/>
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="testCases.CarLoanTest"/>
            <class name="testCases.HomeLoanTest"/>
            <class name="testCases.EmiPageTest"/>
            <class name="testCases.LoanEMITest"/>
            <class name="testCases.TC_EMIPriceTest"/>

        </classes>
    </test>
</suite>